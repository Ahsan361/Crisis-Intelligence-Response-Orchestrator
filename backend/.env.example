# CIRO backend example environment variables
# Copy this file to `.env` and fill in real values before running the backend.

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Google Cloud / Gemini (required for LLM agent client)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional: change the region if needed (defaults to us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

GOOGLE_APPLICATION_CREDENTIALS_JSON=<paste entire json>

# OpenWeatherMap API key (optional; used by weather monitor)
OWM_API_KEY=your_openweathermap_api_key_or_leave_blank
